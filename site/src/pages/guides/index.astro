---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";
import { getCollection } from "astro:content";

const guides = (await getCollection("guides", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order || b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<Layout
  title="Guides — Clawed-Code"
  description="Hands-on guides for working with Claude Code and other coding agents."
>
  <header class="pt-10 pb-8">
    <h1 class="text-4xl font-semibold text-white">Guides</h1>
    <p class="mt-3 max-w-2xl text-ink-200">
      Walkthroughs and playbooks. Ordered from "start here" down to
      deeper-in-the-weeds material.
    </p>
  </header>
  <div class="grid gap-4 sm:grid-cols-2">
    {
      guides.map((g) => (
        <Card
          href={`/guides/${g.id}/`}
          title={g.data.title}
          description={g.data.description}
          meta={fmt(g.data.pubDate)}
          tags={g.data.tags}
        />
      ))
    }
  </div>
</Layout>
