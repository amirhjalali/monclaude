---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("prompts", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} — Clawed-Code`} description={entry.data.description}>
  <article class="mx-auto max-w-2xl pt-10">
    <p class="text-sm text-ink-300">
      <a href="/prompts" class="hover:text-claw-400">← Prompts</a>
    </p>
    <header class="mt-4 border-b border-white/5 pb-8">
      <h1 class="text-3xl font-semibold text-white sm:text-4xl">{entry.data.title}</h1>
      <p class="mt-3 text-ink-200">{entry.data.description}</p>
      <p class="mt-4 text-sm text-ink-300">Agent: {entry.data.agent}</p>
    </header>
    <div class="prose-claw mt-8">
      <Content />
    </div>
  </article>
</Layout>
