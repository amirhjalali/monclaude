---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";
import { getCollection } from "astro:content";

const prompts = (await getCollection("prompts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout
  title="Prompts — Clawed-Code"
  description="Reusable prompts for common coding tasks."
>
  <header class="pt-10 pb-8">
    <h1 class="text-4xl font-semibold text-white">Prompts</h1>
    <p class="mt-3 max-w-2xl text-ink-200">
      Short prompts that reliably earn their keep. Copy, paste, adapt.
    </p>
  </header>
  <div class="grid gap-4 sm:grid-cols-2">
    {
      prompts.map((p) => (
        <Card
          href={`/prompts/${p.id}/`}
          title={p.data.title}
          description={p.data.description}
          meta={p.data.agent}
          tags={p.data.tags}
        />
      ))
    }
  </div>
</Layout>
