---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("tools", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} — Clawed-Code`} description={entry.data.description}>
  <article class="mx-auto max-w-2xl pt-10">
    <p class="text-sm text-ink-300">
      <a href="/tools" class="hover:text-claw-400">← Tools</a>
    </p>
    <header class="mt-4 border-b border-white/5 pb-8">
      <h1 class="text-3xl font-semibold text-white sm:text-4xl">{entry.data.title}</h1>
      <p class="mt-3 text-ink-200">{entry.data.description}</p>
      <div class="mt-5 flex flex-wrap gap-3 text-sm">
        {
          entry.data.repo && (
            <a
              class="rounded-md border border-white/10 px-3 py-1.5 hover:border-claw-500 hover:text-white"
              href={entry.data.repo}
            >
              Source ↗
            </a>
          )
        }
        {
          entry.data.homepage && (
            <a
              class="rounded-md border border-white/10 px-3 py-1.5 hover:border-claw-500 hover:text-white"
              href={entry.data.homepage}
            >
              Homepage ↗
            </a>
          )
        }
      </div>
    </header>
    <div class="prose-claw mt-8">
      <Content />
    </div>
  </article>
</Layout>
