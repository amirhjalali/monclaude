---
interface Props {
  href: string;
  title: string;
  description: string;
  meta?: string;
  tags?: string[];
}
const { href, title, description, meta, tags = [] } = Astro.props;
---

<a
  href={href}
  class="group block rounded-xl border border-white/5 bg-white/[0.02] p-5 transition hover:-translate-y-0.5 hover:border-claw-500/60 hover:bg-white/[0.04]"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-lg font-semibold text-white group-hover:text-claw-400">
      {title}
    </h3>
    {meta && <span class="shrink-0 text-xs text-ink-300">{meta}</span>}
  </div>
  <p class="mt-2 text-sm text-ink-200">{description}</p>
  {
    tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {tags.map((t) => (
          <span class="rounded-full border border-white/5 bg-white/[0.04] px-2 py-0.5 text-xs text-ink-300">
            {t}
          </span>
        ))}
      </div>
    )
  }
</a>
